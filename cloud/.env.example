# Database Configuration
DB_ROOT_PASSWORD=rootpassword
DB_NAME=tonround_cloud
DB_USER=tonround
DB_PASSWORD=tonround

# JWT Secret (Change in production!)
JWT_SECRET=change-this-in-production

# Public URL used for browser redirects and app authorization callbacks
FRONTEND_URL=https://toncloud.sprink.cloud

# Cloudflare Tunnel token for toncloud.sprink.cloud
# In Cloudflare Zero Trust, set the public hostname to:
#   toncloud.sprink.cloud -> http://frontend:80
CLOUDFLARED_TUNNEL_TOKEN=

# Access Key (Optional - Leave empty to disable authentication)
# Set this to a secure random string to require authentication
ACCESS_KEY=
